# Copy to .env in the project root, then start the stack:
#   cp .env.docker.example .env
#
# Local / default:
#   docker compose up -d --build
#   # or: podman compose up -d --build
#
# Low-memory / production VPS (base + explicit overlay):
#   docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d --build
#   # or: podman compose -f docker-compose.yml -f docker-compose.vps.yml up -d --build
#
# Change host ports if 3000, 4000, or 5432 are already taken on this server.
# Postgres is always bound to 127.0.0.1 (not the public NIC).
# Example for a busy host:
#   VENTWALL_WEB_PORT=3100
#   VENTWALL_API_PORT=4100
#   VENTWALL_POSTGRES_PORT=55432
#   CLIENT_ORIGIN=http://localhost:3100
#
# Run multiple isolated stacks on one machine with different ports + project names:
#   COMPOSE_PROJECT_NAME=ventwall-staging docker compose up -d --build

# --- Published host ports ---
VENTWALL_WEB_PORT=3000
VENTWALL_API_PORT=4000
VENTWALL_POSTGRES_PORT=5432

# Browser origin for CORS (must match how you open the web UI — scheme + host + port)
# Local:  http://localhost:3000
# VPS:    https://your-domain.example  (or http://YOUR_SERVER_IP:3000)
CLIENT_ORIGIN=http://localhost:3000
# Local true; on a public VPS set false unless you only use localhost tunnels
ALLOW_LOCALHOST_CORS=true

# --- PostgreSQL ---
POSTGRES_USER=ventwall
POSTGRES_PASSWORD=ventwall
POSTGRES_DB=ventwall

# --- API secrets (required; generate with: openssl rand -hex 32) ---
JWT_SECRET=replace-with-openssl-rand-hex-32
IP_HASH_SECRET=replace-with-another-openssl-rand-hex-32

# --- Optional (runtime only — set here, NOT in server/.env for Docker) ---
# Get a key at https://partner.klipy.com/api-keys
# No rebuild needed: set the key, then run `docker compose up -d api`
KLIPY_API_KEY=
ADMIN_USER_IDS=u09
# Set to false after the first successful start to skip demo seed on restarts
VENTWALL_SEED_DB=true

# --- Low-memory VPS Docker web build ---
# Node heap (MB) during `vite build`. Base compose defaults to 768; vps overlay to 512.
# If the web image still OOMs: add 2G swap (see README) or raise this if RAM allows.
# Sequential build: docker compose -f docker-compose.yml -f docker-compose.vps.yml build --parallel 1
NODE_MAX_OLD_SPACE_SIZE=512