# syntax=docker/dockerfile:1
# Multi-stage web build tuned for low-memory VPS hosts.

FROM node:22-alpine AS build
WORKDIR /app

# Avoid noisy/optional tooling overhead
ENV NPM_CONFIG_UPDATE_NOTIFIER=false \
    NPM_CONFIG_FUND=false \
    NPM_CONFIG_AUDIT=false

COPY package.json package-lock.json ./
# Prefer offline-friendly, clean install; omit optional native extras when possible
RUN npm ci --no-audit --no-fund

COPY index.html vite.config.ts tsconfig.json tsconfig.node.json postcss.config.js tailwind.config.js ./
COPY src ./src

ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL

# Heap size for Node during vite build (MB). Raise if build still OOM and the host has RAM/swap.
# Default 768 works with ~1–2GB free or a 2GB swap file on small VPS boxes.
ARG NODE_MAX_OLD_SPACE_SIZE=768
ENV NODE_OPTIONS=--max-old-space-size=${NODE_MAX_OLD_SPACE_SIZE}

# Skip `tsc` in Docker (typecheck locally/CI) — peaks much lower memory than `tsc && vite build`
# Globe/three bundle is the main RAM consumer.
RUN npm run build:docker

FROM nginx:1.27-alpine AS runner
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
