# Backend — copy to server/.env

DATABASE_URL=postgresql://ventwall:ventwall@localhost:5432/ventwall

# Production: use openssl rand -hex 32 for each secret (32+ chars required)
JWT_SECRET=change-this-to-a-long-random-string-in-production
IP_HASH_SECRET=change-this-to-another-long-random-string-in-production

PORT=4000
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development

# KLIPY GIF API — https://partner.klipy.com/api-keys
# Ads are disabled in Vent Wall; only GIF search + temporary cache are used.
KLIPY_API_KEY=paste-your-klipy-api-key-here

# Comma-separated user ids with admin dashboard access (2–5 people)
# Example: ADMIN_USER_IDS=u09
ADMIN_USER_IDS=